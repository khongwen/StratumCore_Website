---
const year = new Date().getFullYear();
---

<footer id="site-footer">
  <div class="max-w-site mx-auto px-6 lg:px-10">

    <!-- Main footer grid -->
    <div class="py-16 grid grid-cols-1 md:grid-cols-3 gap-12 lg:gap-16">

      <!-- Col 1: Brand -->
      <div>
        <a href="/" class="footer-wordmark" aria-label="StratumCore home">
          <span class="part-stratum">Stratum</span><span class="part-core">Core</span>
        </a>
        <p class="mt-4 text-sm leading-relaxed" style="color: rgba(255,255,255,0.35); font-family: Georgia, serif; max-width: 18rem;">
          Finance &amp; leadership consulting for organisations across Brisbane and Australia.
        </p>
      </div>

      <!-- Col 2: Links -->
      <div>
        <p class="footer-heading">Services</p>
        <ul class="space-y-2.5">
          <li><a href="/finance-consulting"              class="footer-link">Finance Consulting</a></li>
          <li><a href="/leadership-development"          class="footer-link">Leadership Development</a></li>
          <li><a href="/finance-business-partner-academy" class="footer-link">FBP Academy</a></li>
        </ul>
        <p class="footer-heading mt-6">Company</p>
        <ul class="space-y-2.5">
          <li><a href="/"      class="footer-link">Home</a></li>
          <li><a href="/about" class="footer-link">About</a></li>
        </ul>
      </div>

      <!-- Col 3: Contact -->
      <div>
        <p class="footer-heading">Contact</p>
        <ul class="space-y-3">
          <li>
            <a href="mailto:wen@stratumcore.com.au" class="footer-link">
              wen@stratumcore.com.au
            </a>
          </li>
          <li>
            <span class="footer-link" style="cursor: default;">Brisbane, QLD, Australia</span>
          </li>
          <li>
            <a href="https://www.linkedin.com/company/stratumcore/"
               target="_blank" rel="noopener noreferrer"
               class="footer-link flex items-center gap-2">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
              LinkedIn
            </a>
          </li>
        </ul>
      </div>

    </div>

    <!-- Bottom bar -->
    <div class="py-6 border-t flex flex-col sm:flex-row items-center justify-between gap-3"
         style="border-color: rgba(255,255,255,0.07);">
      <p class="text-xs" style="color: rgba(255,255,255,0.22); font-family: Georgia, serif;">
        &copy; {year} StratumCore. All rights reserved.
      </p>
      <p class="text-xs" style="color: rgba(255,255,255,0.18); font-family: Georgia, serif;">
        Brisbane, Queensland, Australia
      </p>
    </div>

  </div>
</footer>
