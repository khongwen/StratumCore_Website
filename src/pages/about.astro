---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="About StratumCore | Finance & Leadership Consulting, Brisbane"
  description="StratumCore is a principal-led advisory partnership specialising in mining and resource-sector finance. Senior from day one — no junior consultants, no templated solutions."
  canonical="https://www.stratumcore.com.au/about"
  ogImageAlt="About StratumCore"
>

  <Nav />

  <!-- ══════════════════════════════════════════════════════════
       1. PAGE HERO
  ══════════════════════════════════════════════════════════ -->
  <section
    class="hero-dark flex items-end relative overflow-hidden"
    style="min-height: 65vh;"
    aria-label="About StratumCore"
  >
    <div
      class="absolute inset-0 pointer-events-none"
      style="
        background-image:
          radial-gradient(ellipse 55% 65% at 95% 5%,  rgba(0,201,187,0.06) 0%, transparent 55%),
          radial-gradient(ellipse 40% 50% at 5%  90%, rgba(212,117,26,0.04) 0%, transparent 50%),
          linear-gradient(rgba(255,255,255,0.012) 1px, transparent 1px),
          linear-gradient(90deg, rgba(255,255,255,0.012) 1px, transparent 1px);
        background-size: auto, auto, 72px 72px, 72px 72px;
      "
      aria-hidden="true"
    ></div>

    <div class="relative z-10 max-w-site mx-auto px-6 lg:px-10 pb-20 pt-[72px] w-full">
      <div class="max-w-4xl fade-up">

        <p class="page-label mb-6">About StratumCore</p>
        <span class="teal-rule mb-8 block"></span>

        <h1
          class="font-serif font-bold text-white leading-none"
          style="font-size: clamp(2.2rem, 5vw, 4.75rem); letter-spacing: -0.03em; max-width: 34rem; line-height: 1.05;"
        >
          Built by someone who's done the job.
        </h1>

        <p
          class="font-serif mt-6 leading-relaxed"
          style="font-size: clamp(0.9375rem, 1.3vw, 1.125rem); color: rgba(255,255,255,0.50); max-width: 38rem; line-height: 1.75;"
        >
          StratumCore is an independent advisory partnership. No junior consultants.
          No templated solutions.
        </p>

      </div>
    </div>
  </section>


  <!-- ══════════════════════════════════════════════════════════
       2. WEN'S BIO
  ══════════════════════════════════════════════════════════ -->
  <section class="bg-white py-24 lg:py-32 border-b" style="border-color: #EBEBEB;" aria-label="Wen Khong">
    <div class="max-w-site mx-auto px-6 lg:px-10">
      <div class="grid lg:grid-cols-5 gap-12 lg:gap-20 items-start">

        <!-- Photo — narrower left col -->
        <div class="lg:col-span-2 fade-up">
          <div class="w-full rounded-sm overflow-hidden relative" style="aspect-ratio: 3/4; max-width: 360px;">
            <img
              src="/profile/Wen Profile picture 2.png"
              alt="Wen Khong, Principal at StratumCore"
              class="w-full h-full object-cover object-top"
              loading="eager"
            />
            <div class="absolute bottom-0 left-0 w-full h-1" style="background: #00C9BB;"></div>
          </div>
        </div>

        <!-- Bio text — wider right col -->
        <div class="lg:col-span-3 fade-up" style="transition-delay: 80ms;">

          <p
            class="font-serif font-bold mb-2"
            style="font-size: 0.75rem; letter-spacing: 0.14em; text-transform: uppercase; color: #00C9BB;"
          >
            Principal | StratumCore
          </p>

          <h2
            class="font-serif font-bold text-body mb-8"
            style="font-size: clamp(1.75rem, 2.8vw, 2.5rem); letter-spacing: -0.025em; line-height: 1.1;"
          >
            Wen Khong
          </h2>

          <div
            class="font-serif leading-relaxed space-y-5"
            style="font-size: 1rem; color: rgba(34,34,34,0.72); line-height: 1.85; max-width: 34rem;"
          >
            <p>
              Wen is a finance and transformation leader with experience supporting
              large asset-intensive organisations across mining and industrial sectors.
              He has delivered initiatives focused on finance capability improvement,
              operational performance, and financial governance — helping leadership
              teams strengthen financial insight and decision support.
            </p>
            <p>
              Having spent time on the other side of the fence as a Production Coal
              Manager, his work focuses on improving how finance teams partner better
              with operational leaders and support more disciplined operational and
              capital decision-making.
            </p>
            <p>
              Wen is a Chartered Accountant (CA ANZ) and Chartered Secretary (AGIA),
              holds a Bachelor of Commerce in Professional Accounting and Finance, and
              is a Harvard Business School alumnus.
            </p>
            <p>
              He founded StratumCore to give mid-market businesses direct access to
              that depth of experience, without the overhead of a large firm.
            </p>
          </div>

          <!-- Credential badges -->
          <div class="mt-10 flex flex-wrap gap-2">
            {['BHP', 'Wesfarmers', 'BUMA'].map((org) => (
              <span
                class="font-serif font-bold"
                style="font-size: 0.6875rem; letter-spacing: 0.12em; text-transform: uppercase; color: rgba(34,34,34,0.55); background: #F2F2F2; border: 1px solid #E2E2E2; padding: 0.3rem 0.75rem; border-radius: 2px;"
              >
                {org}
              </span>
            ))}
          </div>

        </div>
      </div>
    </div>
  </section>


  <!-- ══════════════════════════════════════════════════════════
       3. CALVIN'S BIO
  ══════════════════════════════════════════════════════════ -->
  <section class="bg-white py-24 lg:py-32" aria-label="Calvin">
    <div class="max-w-site mx-auto px-6 lg:px-10">
      <div class="grid lg:grid-cols-5 gap-12 lg:gap-20 items-start">

        <!-- Photo placeholder — narrower left col -->
        <div class="lg:col-span-2 fade-up">
          <div class="w-full rounded-sm overflow-hidden relative" style="aspect-ratio: 3/4; max-width: 360px;">
            <img
              src="/profile/Calvin Profile picture.jpg"
              alt="Calvin Yong, Associate at StratumCore"
              class="w-full h-full object-cover object-top"
              loading="lazy"
            />
            <div class="absolute bottom-0 left-0 w-full h-1" style="background: #00C9BB;"></div>
          </div>
        </div>

        <!-- Bio text — wider right col -->
        <div class="lg:col-span-3 fade-up" style="transition-delay: 80ms;">

          <p
            class="font-serif font-bold mb-2"
            style="font-size: 0.75rem; letter-spacing: 0.14em; text-transform: uppercase; color: #00C9BB;"
          >
            Associate | StratumCore
          </p>

          <h2
            class="font-serif font-bold text-body mb-8"
            style="font-size: clamp(1.75rem, 2.8vw, 2.5rem); letter-spacing: -0.025em; line-height: 1.1;"
          >
            Calvin Yong
          </h2>

          <div
            class="font-serif leading-relaxed space-y-5"
            style="font-size: 1rem; color: rgba(34,34,34,0.72); line-height: 1.85; max-width: 34rem;"
          >
            <p>
              Calvin has extensive experience across commercial strategy, operational
              performance, and major contract negotiations within large mining and
              industrial organisations.
            </p>
            <p>
              He has worked closely with operational and executive leadership teams
              to improve cost performance, operational effectiveness, and commercial
              outcomes — and has supported major supplier negotiations and capital
              investment decisions. Calvin's approach is grounded in delivery,
              ensuring initiatives are not only well-defined but executed effectively
              to achieve measurable results. He is known for clear, structured
              thinking that cuts through complexity and challenges assumptions.
            </p>
            <p>
              Calvin holds an MBA from The University of Queensland, is a Certified
              Practising Accountant (CPA), and holds a Bachelor of Commerce in
              Accounting and Finance.
            </p>
          </div>

          <!-- Credential badges -->
          <div class="mt-10 flex flex-wrap gap-2">
            {['BMA', 'BHP', 'BUMA'].map((org) => (
              <span
                class="font-serif font-bold"
                style="font-size: 0.6875rem; letter-spacing: 0.12em; text-transform: uppercase; color: rgba(34,34,34,0.55); background: #F2F2F2; border: 1px solid #E2E2E2; padding: 0.3rem 0.75rem; border-radius: 2px;"
              >
                {org}
              </span>
            ))}
          </div>

        </div>
      </div>
    </div>
  </section>


  <!-- ══════════════════════════════════════════════════════════
       4. WHY STRATUMCORE — Stone bg, three-column
  ══════════════════════════════════════════════════════════ -->
  <section class="py-24 lg:py-32" style="background: #F2F2F2;" aria-label="Our philosophy">
    <div class="max-w-site mx-auto px-6 lg:px-10">

      <div class="mb-16 fade-up">
        <p class="page-label mb-4">Our philosophy</p>
        <h2
          class="font-serif font-bold text-body"
          style="font-size: clamp(1.75rem, 3vw, 2.75rem); letter-spacing: -0.025em; line-height: 1.1; max-width: 28rem;"
        >
          What makes us different.
        </h2>
      </div>

      <div class="grid md:grid-cols-3 gap-px" style="background: #DCDCDC;">

        <article class="diff-card bg-stone p-8 lg:p-10 fade-up" style="transition-delay: 0ms;">
          <div class="mb-5" style="width: 2.5rem; height: 2px; background: #00C9BB; border-radius: 1px;"></div>
          <h3 class="font-serif font-bold text-body mb-3" style="font-size: 1.125rem; letter-spacing: -0.02em; line-height: 1.2;">
            Senior from day one
          </h3>
          <p class="font-serif leading-relaxed" style="font-size: 0.9375rem; color: rgba(34,34,34,0.62); line-height: 1.75;">
            You get Wen, not a graduate with a framework.
          </p>
        </article>

        <article class="diff-card bg-stone p-8 lg:p-10 fade-up" style="transition-delay: 80ms;">
          <div class="mb-5" style="width: 2.5rem; height: 2px; background: #00C9BB; border-radius: 1px;"></div>
          <h3 class="font-serif font-bold text-body mb-3" style="font-size: 1.125rem; letter-spacing: -0.02em; line-height: 1.2;">
            Independent
          </h3>
          <p class="font-serif leading-relaxed" style="font-size: 0.9375rem; color: rgba(34,34,34,0.62); line-height: 1.75;">
            No conflicts, no product to sell, no firm politics.
          </p>
        </article>

        <article class="diff-card bg-stone p-8 lg:p-10 fade-up" style="transition-delay: 160ms;">
          <div class="mb-5" style="width: 2.5rem; height: 2px; background: #00C9BB; border-radius: 1px;"></div>
          <h3 class="font-serif font-bold text-body mb-3" style="font-size: 1.125rem; letter-spacing: -0.02em; line-height: 1.2;">
            Sector-specific
          </h3>
          <p class="font-serif leading-relaxed" style="font-size: 0.9375rem; color: rgba(34,34,34,0.62); line-height: 1.75;">
            We know mining finance. We don't need a learning curve at your expense.
          </p>
        </article>

      </div>
    </div>
  </section>


  <!-- ══════════════════════════════════════════════════════════
       5. PARTNERSHIPS — White, prose
  ══════════════════════════════════════════════════════════ -->
  <section class="bg-white py-24 lg:py-32" aria-label="How we work">
    <div class="max-w-site mx-auto px-6 lg:px-10">
      <div class="grid lg:grid-cols-2 gap-16 lg:gap-24 items-start">

        <div class="fade-up">
          <p class="page-label mb-4" style="color: #00C9BB;">How we work</p>
          <h2
            class="font-serif font-bold text-body"
            style="font-size: clamp(1.75rem, 2.8vw, 2.5rem); letter-spacing: -0.025em; line-height: 1.1; max-width: 22rem;"
          >
            Principal-led. Always.
          </h2>
        </div>

        <div class="fade-up" style="transition-delay: 80ms;">
          <p
            class="font-serif leading-relaxed mb-6"
            style="font-size: 1rem; color: rgba(34,34,34,0.70); line-height: 1.85; max-width: 34rem;"
          >
            StratumCore operates as a principal-led advisory partnership. For
            engagements that require broader capability, we draw on a trusted
            network of senior independent specialists — all with mining or resources
            backgrounds.
          </p>
          <p
            class="font-serif"
            style="font-size: 0.875rem; color: rgba(34,34,34,0.40); line-height: 1.7;"
          >
            StratumCore is the trading entity of StratumCore Pty Ltd.
            ABN: 61 696 477 406.
          </p>
        </div>

      </div>
    </div>
  </section>


  <!-- ══════════════════════════════════════════════════════════
       6. CLOSING CTA
  ══════════════════════════════════════════════════════════ -->
  <section
    class="py-24 lg:py-32 relative overflow-hidden"
    aria-label="Contact"
    style="background: #00C9BB;"
  >
    <div
      class="absolute inset-0 pointer-events-none"
      style="background-image: linear-gradient(rgba(255,255,255,0.04) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.04) 1px, transparent 1px); background-size: 60px 60px;"
      aria-hidden="true"
    ></div>

    <div class="relative z-10 max-w-site mx-auto px-6 lg:px-10 text-center fade-up">
      <h2
        class="font-serif font-bold mb-3 mx-auto"
        style="font-size: clamp(2rem, 4vw, 3.5rem); color: #1C1C1E; letter-spacing: -0.03em; line-height: 1.1;"
      >
        Let's talk.
      </h2>
      <p
        class="font-serif mb-8 mx-auto"
        style="font-size: 1.0625rem; color: rgba(28,28,30,0.60); max-width: 28rem; line-height: 1.7;"
      >
        Discovery calls are free, focused, and no obligation.
      </p>
      <a
        href="mailto:wen@stratumcore.com.au"
        class="font-serif font-bold inline-flex items-center gap-3 px-8 py-4 rounded-sm"
        style="background: #1C1C1E; color: #FFFFFF; font-size: 0.9375rem; letter-spacing: 0.02em; text-decoration: none; box-shadow: 0 4px 16px rgba(28,28,30,0.2); transition: background 0.18s ease, transform 0.18s cubic-bezier(0.34,1.56,0.64,1), box-shadow 0.18s ease;"
        onmouseover="this.style.background='#2d2d30'; this.style.transform='translateY(-2px)'; this.style.boxShadow='0 8px 24px rgba(28,28,30,0.35)'"
        onmouseout="this.style.background='#1C1C1E'; this.style.transform='translateY(0)'; this.style.boxShadow='0 4px 16px rgba(28,28,30,0.2)'"
      >
        Book a call
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M2 8h12M9 3l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
      <p
        class="font-serif mt-5"
        style="font-size: 0.875rem; color: rgba(28,28,30,0.55);"
      >
        wen@stratumcore.com.au &nbsp;·&nbsp; Brisbane, QLD, Australia
      </p>
    </div>
  </section>

  <Footer />

</BaseLayout>

<style>
  .diff-card {
    border-top: 2px solid transparent;
    transition: border-color 0.22s ease;
  }
  .diff-card:hover {
    border-top-color: #00C9BB;
  }
</style>

<script>
  const observer = new IntersectionObserver(entries => {
    entries.forEach(e => {
      if (e.isIntersecting) { e.target.classList.add('visible'); observer.unobserve(e.target); }
    });
  }, { threshold: 0.07, rootMargin: '0px 0px -40px 0px' });

  document.querySelectorAll('.fade-up').forEach(el => observer.observe(el));
  setTimeout(() => document.querySelectorAll('.fade-up').forEach(el => el.classList.add('visible')), 80);
</script>
