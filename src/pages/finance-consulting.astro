---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Finance Consulting for Mining & Resources | StratumCore"
  description="CFO advisory, cost diagnostics, and financial performance improvement for mining and resource businesses. Senior, independent finance consulting across Brisbane and Australia."
  canonical="https://www.stratumcore.com.au/finance-consulting"
  ogImageAlt="Finance Consulting — StratumCore"
>

  <Nav />

  <!-- ══════════════════════════════════════════════════════════
       1. PAGE HERO
  ══════════════════════════════════════════════════════════ -->
  <section
    class="hero-dark flex items-end relative overflow-hidden"
    style="min-height: 65vh;"
    aria-label="Finance Consulting"
  >
    <!-- Background treatment -->
    <div
      class="absolute inset-0 pointer-events-none"
      style="
        background-image:
          radial-gradient(ellipse 55% 60% at 100% 0%,  rgba(0,201,187,0.06) 0%, transparent 55%),
          radial-gradient(ellipse 35% 45% at 0%  100%, rgba(212,117,26,0.04) 0%, transparent 50%),
          linear-gradient(rgba(255,255,255,0.012) 1px, transparent 1px),
          linear-gradient(90deg, rgba(255,255,255,0.012) 1px, transparent 1px);
        background-size: auto, auto, 72px 72px, 72px 72px;
      "
      aria-hidden="true"
    ></div>

    <div class="relative z-10 max-w-site mx-auto px-6 lg:px-10 pb-20 pt-[72px] w-full">
      <div class="max-w-4xl fade-up">

        <p class="page-label mb-6">Finance Consulting</p>
        <span class="teal-rule mb-8 block"></span>

        <h1
          class="font-serif font-bold text-white mb-0 leading-none"
          style="font-size: clamp(2.2rem, 5vw, 4.75rem); letter-spacing: -0.03em; max-width: 38rem; line-height: 1.05;"
        >
          Finance consulting for mining and resource businesses.
        </h1>

        <p
          class="font-serif font-bold mt-6"
          style="font-size: clamp(1rem, 1.6vw, 1.25rem); color: #00C9BB; letter-spacing: -0.01em;"
        >
          Practical. Senior. Independent.
        </p>

        <p
          class="font-serif mt-4 leading-relaxed"
          style="font-size: clamp(0.9375rem, 1.2vw, 1.0625rem); color: rgba(255,255,255,0.50); max-width: 38rem; line-height: 1.75;"
        >
          We work with mining operators, contractors, and asset-intensive businesses
          who need experienced finance leadership — for a project, a diagnostic, or
          ongoing advisory support.
        </p>

      </div>
    </div>
  </section>


  <!-- ══════════════════════════════════════════════════════════
       2. WHAT WE OFFER — Service tiles
  ══════════════════════════════════════════════════════════ -->
  <section class="bg-white py-24 lg:py-32" aria-label="Services">
    <div class="max-w-site mx-auto px-6 lg:px-10">

      <div class="mb-16 fade-up">
        <p class="page-label mb-4" style="color: #00C9BB;">Services</p>
        <h2
          class="font-serif font-bold text-body"
          style="font-size: clamp(1.75rem, 3vw, 2.75rem); letter-spacing: -0.025em; line-height: 1.1; max-width: 26rem;"
        >
          Where we add value.
        </h2>
      </div>

      <!-- 2-column tile grid — gap-px on bg-stone creates hairline dividers -->
      <div class="grid md:grid-cols-2 gap-px" style="background: #E8E8E8;">

        <article class="service-tile bg-white p-8 lg:p-10 fade-up" style="transition-delay: 0ms;">
          <p class="tile-number mb-5">01</p>
          <h3 class="font-serif font-bold text-body mb-3" style="font-size: clamp(1.125rem, 1.5vw, 1.375rem); letter-spacing: -0.02em; line-height: 1.2;">
            CFO Advisory
          </h3>
          <p class="font-serif leading-relaxed" style="font-size: 0.9375rem; color: rgba(34,34,34,0.62); line-height: 1.75;">
            Fractional or project-based CFO support for businesses that need senior
            financial leadership without a full-time hire.
          </p>
        </article>

        <article class="service-tile bg-white p-8 lg:p-10 fade-up" style="transition-delay: 60ms;">
          <p class="tile-number mb-5">02</p>
          <h3 class="font-serif font-bold text-body mb-3" style="font-size: clamp(1.125rem, 1.5vw, 1.375rem); letter-spacing: -0.02em; line-height: 1.2;">
            Cost Diagnostics
          </h3>
          <p class="font-serif leading-relaxed" style="font-size: 0.9375rem; color: rgba(34,34,34,0.62); line-height: 1.75;">
            Structured programmes to identify cost improvement opportunities across
            operations, overhead, and capital spend.
          </p>
        </article>

        <article class="service-tile bg-white p-8 lg:p-10 fade-up" style="transition-delay: 120ms;">
          <p class="tile-number mb-5">03</p>
          <h3 class="font-serif font-bold text-body mb-3" style="font-size: clamp(1.125rem, 1.5vw, 1.375rem); letter-spacing: -0.02em; line-height: 1.2;">
            Financial Performance Improvement
          </h3>
          <p class="font-serif leading-relaxed" style="font-size: 0.9375rem; color: rgba(34,34,34,0.62); line-height: 1.75;">
            From reporting redesign to driver-based modelling, we help finance
            functions work harder for the business.
          </p>
        </article>

        <article class="service-tile bg-white p-8 lg:p-10 fade-up" style="transition-delay: 180ms;">
          <p class="tile-number mb-5">04</p>
          <h3 class="font-serif font-bold text-body mb-3" style="font-size: clamp(1.125rem, 1.5vw, 1.375rem); letter-spacing: -0.02em; line-height: 1.2;">
            Business Case Development
          </h3>
          <p class="font-serif leading-relaxed" style="font-size: 0.9375rem; color: rgba(34,34,34,0.62); line-height: 1.75;">
            Rigorous investment analysis and business cases that withstand executive
            and board scrutiny.
          </p>
        </article>

        <article class="service-tile bg-white p-8 lg:p-10 fade-up" style="transition-delay: 240ms;">
          <p class="tile-number mb-5">05</p>
          <h3 class="font-serif font-bold text-body mb-3" style="font-size: clamp(1.125rem, 1.5vw, 1.375rem); letter-spacing: -0.02em; line-height: 1.2;">
            Financial Due Diligence
          </h3>
          <p class="font-serif leading-relaxed" style="font-size: 0.9375rem; color: rgba(34,34,34,0.62); line-height: 1.75;">
            Commercial and financial assessment to support acquisitions, disposals,
            and partnerships.
          </p>
        </article>

        <article class="service-tile bg-white p-8 lg:p-10 fade-up" style="transition-delay: 300ms;">
          <p class="tile-number mb-5">06</p>
          <h3 class="font-serif font-bold text-body mb-3" style="font-size: clamp(1.125rem, 1.5vw, 1.375rem); letter-spacing: -0.02em; line-height: 1.2;">
            Finance Function Design
          </h3>
          <p class="font-serif leading-relaxed" style="font-size: 0.9375rem; color: rgba(34,34,34,0.62); line-height: 1.75;">
            Structure, process, and capability assessments to help your finance team
            scale with the business.
          </p>
        </article>

      </div>
    </div>
  </section>


  <!-- ══════════════════════════════════════════════════════════
       3. OUR APPROACH — Horizontal steps
  ══════════════════════════════════════════════════════════ -->
  <section class="py-24 lg:py-32" style="background: #F2F2F2;" aria-label="Our approach">
    <div class="max-w-site mx-auto px-6 lg:px-10">

      <div class="mb-16 fade-up">
        <p class="page-label mb-4">Our approach</p>
        <h2
          class="font-serif font-bold text-body"
          style="font-size: clamp(1.75rem, 3vw, 2.75rem); letter-spacing: -0.025em; line-height: 1.1; max-width: 30rem;"
        >
          How a typical engagement works.
        </h2>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-px" style="background: #E0E0E0;">

        <div class="bg-stone p-8 lg:p-10 fade-up" style="transition-delay: 0ms;">
          <span
            class="font-serif font-bold inline-block mb-5"
            style="font-size: 0.625rem; letter-spacing: 0.14em; text-transform: uppercase; color: #1C1C1E; background: #00C9BB; padding: 0.2rem 0.55rem; border-radius: 2px;"
          >Step 01</span>
          <h3 class="font-serif font-bold text-body mb-3" style="font-size: 1.125rem; letter-spacing: -0.015em;">
            Scoping
          </h3>
          <p class="font-serif" style="font-size: 0.9rem; color: rgba(34,34,34,0.58); line-height: 1.7;">
            A focused conversation to understand your situation, constraints, and what success looks like.
          </p>
        </div>

        <div class="bg-stone p-8 lg:p-10 fade-up" style="transition-delay: 80ms;">
          <span
            class="font-serif font-bold inline-block mb-5"
            style="font-size: 0.625rem; letter-spacing: 0.14em; text-transform: uppercase; color: #1C1C1E; background: #00C9BB; padding: 0.2rem 0.55rem; border-radius: 2px;"
          >Step 02</span>
          <h3 class="font-serif font-bold text-body mb-3" style="font-size: 1.125rem; letter-spacing: -0.015em;">
            Diagnostic
          </h3>
          <p class="font-serif" style="font-size: 0.9rem; color: rgba(34,34,34,0.58); line-height: 1.7;">
            Deep-dive analysis of your finances, processes, and team to identify the real levers.
          </p>
        </div>

        <div class="bg-stone p-8 lg:p-10 fade-up" style="transition-delay: 160ms;">
          <span
            class="font-serif font-bold inline-block mb-5"
            style="font-size: 0.625rem; letter-spacing: 0.14em; text-transform: uppercase; color: #1C1C1E; background: #00C9BB; padding: 0.2rem 0.55rem; border-radius: 2px;"
          >Step 03</span>
          <h3 class="font-serif font-bold text-body mb-3" style="font-size: 1.125rem; letter-spacing: -0.015em;">
            Recommendations
          </h3>
          <p class="font-serif" style="font-size: 0.9rem; color: rgba(34,34,34,0.58); line-height: 1.7;">
            Clear, prioritised recommendations with a realistic path to implementation.
          </p>
        </div>

        <div class="bg-stone p-8 lg:p-10 fade-up" style="transition-delay: 240ms;">
          <span
            class="font-serif font-bold inline-block mb-5"
            style="font-size: 0.625rem; letter-spacing: 0.14em; text-transform: uppercase; color: rgba(28,28,30,0.38); background: rgba(28,28,30,0.07); padding: 0.2rem 0.55rem; border-radius: 2px;"
          >Step 04</span>
          <h3 class="font-serif font-bold text-body mb-3" style="font-size: 1.125rem; letter-spacing: -0.015em;">
            Implementation support
          </h3>
          <p class="font-serif" style="font-size: 0.9rem; color: rgba(34,34,34,0.58); line-height: 1.7;">
            We stay involved to make sure changes land, not just as a report on a shelf.
          </p>
        </div>

      </div>
    </div>
  </section>


  <!-- ══════════════════════════════════════════════════════════
       4. WHO WE WORK WITH
  ══════════════════════════════════════════════════════════ -->
  <section class="bg-white py-24 lg:py-32" aria-label="Who we work with">
    <div class="max-w-site mx-auto px-6 lg:px-10">

      <div class="grid lg:grid-cols-2 gap-16 lg:gap-24 items-start">

        <!-- Left: heading + intro -->
        <div class="fade-up">
          <p class="page-label mb-4" style="color: #00C9BB;">Who we work with</p>
          <h2
            class="font-serif font-bold text-body mb-6"
            style="font-size: clamp(1.75rem, 3vw, 2.75rem); letter-spacing: -0.025em; line-height: 1.1; max-width: 22rem;"
          >
            Built for businesses like yours.
          </h2>
          <p
            class="font-serif leading-relaxed"
            style="font-size: 1rem; color: rgba(34,34,34,0.60); line-height: 1.8; max-width: 28rem;"
          >
            We are not a generalist firm. Every engagement draws on deep experience
            in resource-sector finance — which means we get to the issues faster and
            speak your language from day one.
          </p>
        </div>

        <!-- Right: two-column bullet lists -->
        <div class="fade-up" style="transition-delay: 80ms;">
          <div class="grid sm:grid-cols-2 gap-x-10">

            <ul role="list">
              {[
                'Mid-tier mining operators',
                'Mining contractors and services companies',
                'Asset-intensive industrials',
              ].map((item) => (
                <li class="client-bullet font-serif py-4" style="font-size: 0.9375rem; color: rgba(34,34,34,0.75); line-height: 1.5; border-bottom: 1px solid #EBEBEB;">
                  <span class="bullet-dot" aria-hidden="true"></span>
                  {item}
                </li>
              ))}
            </ul>

            <ul role="list">
              {[
                'Finance teams building capability',
                'Boards and executives seeking independent review',
                'PE-backed resource businesses',
              ].map((item) => (
                <li class="client-bullet font-serif py-4" style="font-size: 0.9375rem; color: rgba(34,34,34,0.75); line-height: 1.5; border-bottom: 1px solid #EBEBEB;">
                  <span class="bullet-dot" aria-hidden="true"></span>
                  {item}
                </li>
              ))}
            </ul>

          </div>
        </div>

      </div>
    </div>
  </section>


  <!-- ══════════════════════════════════════════════════════════
       5. CLOSING CTA
  ══════════════════════════════════════════════════════════ -->
  <section
    class="py-24 lg:py-32 relative overflow-hidden"
    aria-label="Contact"
    style="background: #00C9BB;"
  >
    <div
      class="absolute inset-0 pointer-events-none"
      style="background-image: linear-gradient(rgba(255,255,255,0.04) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.04) 1px, transparent 1px); background-size: 60px 60px;"
      aria-hidden="true"
    ></div>

    <div class="relative z-10 max-w-site mx-auto px-6 lg:px-10 text-center fade-up">
      <h2
        class="font-serif font-bold mb-8 mx-auto"
        style="font-size: clamp(1.75rem, 3.5vw, 3rem); color: #1C1C1E; letter-spacing: -0.025em; line-height: 1.2; max-width: 36rem;"
      >
        Let's talk about what's actually holding your business back.
      </h2>
      <a
        href="mailto:wen@stratumcore.com.au"
        class="font-serif font-bold inline-flex items-center gap-3 px-8 py-4 rounded-sm"
        style="background: #1C1C1E; color: #FFFFFF; font-size: 0.9375rem; letter-spacing: 0.02em; text-decoration: none; box-shadow: 0 4px 16px rgba(28,28,30,0.2); transition: background 0.18s ease, transform 0.18s cubic-bezier(0.34,1.56,0.64,1), box-shadow 0.18s ease;"
        onmouseover="this.style.background='#2d2d30'; this.style.transform='translateY(-2px)'; this.style.boxShadow='0 8px 24px rgba(28,28,30,0.35)'"
        onmouseout="this.style.background='#1C1C1E'; this.style.transform='translateY(0)'; this.style.boxShadow='0 4px 16px rgba(28,28,30,0.2)'"
      >
        Book a call
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M2 8h12M9 3l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
      <p
        class="font-serif mt-5"
        style="font-size: 0.875rem; color: rgba(28,28,30,0.55);"
      >
        wen@stratumcore.com.au &nbsp;·&nbsp; Brisbane, QLD, Australia
      </p>
    </div>
  </section>

  <Footer />

</BaseLayout>

<style>
  .service-tile {
    border-top: 2px solid transparent;
    transition: border-color 0.22s ease;
  }
  .service-tile:hover {
    border-top-color: #00C9BB;
  }

  .tile-number {
    font-family: Georgia, serif;
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #00C9BB;
  }

  .client-bullet {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
  }
  .bullet-dot {
    display: inline-block;
    flex-shrink: 0;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: #00C9BB;
    margin-top: 0.5em;
  }
</style>

<script>
  const observer = new IntersectionObserver(entries => {
    entries.forEach(e => {
      if (e.isIntersecting) { e.target.classList.add('visible'); observer.unobserve(e.target); }
    });
  }, { threshold: 0.07, rootMargin: '0px 0px -40px 0px' });

  document.querySelectorAll('.fade-up').forEach(el => observer.observe(el));
  setTimeout(() => document.querySelectorAll('.fade-up').forEach(el => el.classList.add('visible')), 80);
</script>
